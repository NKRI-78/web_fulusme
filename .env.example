# Fulusme Web — environment template
# Copy to `.env` (and per-stage `.env.development` / `.env.production`) and fill in.
# All keys below are exposed to the browser (NEXT_PUBLIC_*) — do NOT add real
# secrets here. Server-only secrets (e.g. NEXTAUTH_SECRET) must NOT be prefixed
# with NEXT_PUBLIC_ and must stay out of version control.

# Core REST backend (single source of truth — see CLAUDE.md §1, §12)
NEXT_PUBLIC_API_BACKEND=https://api-staging-fulusme.example.com

# Public base URL of this Next.js app
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Realtime socket.io host
NEXT_PUBLIC_API_SOCKET=https://socketio-staging-fulusme.example.com

# Media upload/serve backend
NEXT_PUBLIC_API_BACKEND_MEDIA=https://api-media-fulusme.example.com

# Payment gateway
NEXT_PUBLIC_API_PG=https://api.pg.example.com

# Payment gateway — banks lookup
NEXT_PUBLIC_API_PG_BANKS=https://api.gateway.example.com/v1
